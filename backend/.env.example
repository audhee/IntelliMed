# -----------------------------------------------------------------------------
# AI-Powered Longitudinal Health Intelligence Platform Backend Config
# -----------------------------------------------------------------------------

# Application Environment
APP_ENV=development
DEBUG=true

# Relational Database Connection (Supabase PostgreSQL or fallback SQLite)
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
# If blank, the app will automatically fall back to local sqlite "health_intelligence.db"
DATABASE_URL=

# Secure JWT Session Configurations
# Generate a secure secret using: openssl rand -hex 32
JWT_SECRET_KEY=supersecretkeychangeinproduction1234567890!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cloudinary File Storage Credentials
# Optional fallback: Local folder static serving if left empty
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Gemini API Key for OCR & safe interpretation
# Generate one from: https://aistudio.google.com/
# Optional fallback: Intelligent offline clinical mockup generator if left empty
GEMINI_API_KEY=

# Upstash Redis Broker (Celery background worker queue & cache)
# Format: redis://:[password]@[host]:[port]/0
# If blank, defaults to local redis
REDIS_URL=redis://localhost:6379/0
